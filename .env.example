# --- MiniMax (the LLM — Phase 1 core) ---
# Negotiator, self-play buyer, optimizer, and verifier all run on MiniMax-M3 via its
# ANTHROPIC-compatible endpoint, wired through Pydantic AI's native AnthropicModel (gambit/llm.py).
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M3
# Tier-2 integrity verifier — optional different model id; falls back to MINIMAX_MODEL
VERIFIER_MODEL=
# Set OFFLINE=1 to run the loop with the deterministic policy, no API key needed
OFFLINE=

# --- Observability (Logfire) ---
# logfire.pydantic.dev -> write token. Optional: without it tracing stays local;
# with it every agent run + the improvement curve land in a live dashboard.
LOGFIRE_TOKEN=

# --- DigitalOcean Managed Postgres + pgvector (storage + memory) ---
# Leave blank to use the in-memory store (the loop still runs).
DATABASE_URL=
# Embeddings for memory retrieval (Phase 2); set EMBED_DIM to the model's output dim.
EMBED_MODEL=
EMBED_DIM=1024

# --- Phase 2: eBay (real-marketplace proof, via the eBay API) ---
EBAY_ENV=SANDBOX
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_USER_TOKEN=

# --- Gemini feature layer (all optional; each degrades to its non-Gemini default) ---
# Managed-agent optimizer (Antigravity, Interactions API) + Nano Banana listing media + Gemini Live.
GEMINI_API_KEY=
# Optimizer backend: "local" (MiniMax, default/offline) | "antigravity" (Gemini managed agent)
OPTIMIZER_BACKEND=local

# --- Voice buyer seat: LiveKit transport + Gemini Live/Translate ---
# Blank → typed human seat only. LiveKit moves the audio; Gemini Live is the brain.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
