# --- DigitalOcean Serverless Inference (Phase 1 core) ---
# Inference -> Serverless -> Create a Model Access Key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1/
# Negotiator (seller) model and the adversarial buyer model
CHAT_MODEL=llama3.3-70b-instruct
BUYER_MODEL=llama3.3-70b-instruct
# Tier-2 integrity verifier (ideally a stronger/different model; falls back to CHAT_MODEL)
VERIFIER_MODEL=
# Set OFFLINE=1 to run the loop with deterministic heuristics, no API key needed
OFFLINE=

# --- DigitalOcean Managed Postgres + pgvector (storage + memory) ---
# Leave blank to use the in-memory store (the loop still runs).
DATABASE_URL=
# Embeddings for memory retrieval (Phase 2); set EMBED_DIM to the model's output dim.
EMBED_MODEL=
EMBED_DIM=1024

# --- Phase 2: eBay Sandbox (real-marketplace proof) ---
EBAY_ENV=SANDBOX
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_OAUTH_USER_TOKEN=

# --- Phase 2: LiveKit (seller voice intake + showcase) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Phase 3 stretch: Gemini (computer-use auto-post) ---
GEMINI_API_KEY=
